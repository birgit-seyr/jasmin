yarn-error.log
.pnp/
.pnp.js
coverage/
build/

# pytest-cov / coverage.py reports + raw data (generated by
# ``poetry run pytest --cov=apps --cov-report=html``). Regenerated
# on every run — never commit these.
htmlcov/
.coverage
.coverage.*
coverage.xml
.DS_Store
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.tmp


# Docker
.env
# Real per-environment secret files (keep only the *.example templates tracked).
# .env.dev holds live DJANGO_SECRET_KEY / FIELD_ENCRYPTION_KEY / POSTGRES_PASSWORD
# and must never be committed — it was purged from history, see docs/secrets-purge.md.
.env.dev
.env.*
!.env*.example

# IDE
.idea/
.vscode/
*.swp
*.swo

# Zertifikate
*.pem
*.key
*.crt

# Certbot DNS plugin credentials (keep .example files committed)
certbots/*.ini
!certbots/*.ini.example

# Backups — encrypted DB dumps must never be committed (keep the scripts).
backups/*.sql
backups/*.sql.gz
backups/*.gpg
backups/*.dump
!backups/*.sh
# Off-host push credentials — rclone config + the dedicated Storage Box key.
backups/rclone.conf
backups/storagebox_key
backups/storagebox_key.pub

*.pdf
# Local AI assistant instructions (kept out of version control)
CLAUDE.md
text.txt

# Local audit / working-note markdown — generated per session, never committed.
# Limited to .md so it never swallows source code that merely contains "audit"
# (the *auditlog* tests, the AuditItems component, check-prod-audit.mjs).
*audit*.md