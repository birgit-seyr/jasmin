# =============================================================================
# Jasmin Platform - PRODUCTION env (copy to .env and fill in)
# NEVER commit the real .env file!
# =============================================================================

# ---- Security ---------------------------------------------------------------
# MUST be False in production. settings.py defaults to False and the compose
# forces it False; never set True on a public deploy.
DEBUG=False
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=change-me-min-50-chars
# Secret-key rotation (optional): during a rotation window set this to the
# PREVIOUS key so in-flight password-reset / invitation links still verify.
# Leave blank otherwise.
DJANGO_SECRET_KEY_FALLBACK=
# python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
FIELD_ENCRYPTION_KEY=change-me-fernet-key
# GPG passphrase that encrypts the nightly DB dumps (backups/backup.sh writes
# *.sql.gz.gpg; restore_drill.sh decrypts with it). REQUIRED for backups —
# store it somewhere OTHER than the backups themselves, or a host loss takes
# the key with the data. Generate: openssl rand -base64 32
BACKUP_ENCRYPTION_KEY=change-me-backup-passphrase
# Cron schedule for the nightly dump (the `backup` service). Default: 02:00
# daily. Quote it if you override (it contains spaces): BACKUP_SCHEDULE="0 2 * * *"
BACKUP_SCHEDULE=0 2 * * *
# Off-host backup push (optional scaffold). Set RCLONE_REMOTE to an rclone
# remote (e.g. "storagebox:jasmin-backups"), mount an rclone config into the
# backup service and point RCLONE_CONFIG at it (see docker-compose.yml), to copy
# each encrypted DB dump + media archive off-host. Empty = local-only backups.
RCLONE_REMOTE=
RCLONE_CONFIG=

# ---- Image tag / rollback ---------------------------------------------------
# Tag for the jasmin/* images (backend, huey, backup, frontend). Build + push
# immutable per-release tags (git SHA / version) and pin here; roll back with
# `IMAGE_TAG=<prev> docker compose up -d <svc>`. Migrations are forward-only, so
# only roll back to a release whose migrations are a prefix of what already ran.
IMAGE_TAG=latest

# ---- Database ---------------------------------------------------------------
POSTGRES_DB=jasmin
POSTGRES_USER=jasmin
POSTGRES_PASSWORD=change-me-strong

# ---- Redis ------------------------------------------------------------------
# Embedded in REDIS_URL (redis://:<password>@redis:6379/...) — use only
# URL-safe characters (letters, digits, - _ ~), no @ : / ? # etc.
# python -c 'import secrets; print(secrets.token_urlsafe(32))'
REDIS_PASSWORD=change-me-url-safe

# ---- Domain & hosts ---------------------------------------------------------
FRONTEND_DOMAIN=jasmin.example.com
# Subdomain that hosts the super-admin UI. Choose a non-obvious word; the host
# is also IP-restricted via nginx/super_admin_allowed_ips.conf. Default: marillen
SUPER_ADMIN_SUBDOMAIN=marillen
# Comma-separated IPs/CIDRs allowed to reach the super-admin API — app-layer
# defense-in-depth behind the nginx edge allowlist. Empty = rely on the nginx
# allowlist only. Keep in sync with nginx/super_admin_allowed_ips.conf when set.
SUPER_ADMIN_ALLOWED_IPS=
DJANGO_ALLOWED_HOSTS=.jasmin.example.com,jasmin.example.com
CORS_ALLOWED_ORIGINS=https://jasmin.example.com
# Optional. CSRF_TRUSTED_ORIGINS is derived automatically from FRONTEND_DOMAIN
# (apex + ``*.`` wildcard). Set this only to trust ADDITIONAL origins — a
# comma-separated list is APPENDED to the derived ones (it no longer overwrites
# them). Leave unset for the standard single-domain deploy.
# CSRF_TRUSTED_ORIGINS=https://extra.example.com

# Number of trusted reverse-proxy hops in front of the app, used to resolve the
# real client IP from X-Forwarded-For (django-axes lockout attribution + DRF
# throttling). The shipped stack has ONE hop — the gateway nginx, no CDN — so 1
# is correct. Bump only if you add a trusted CDN/edge in front of nginx.
TRUSTED_PROXY_COUNT=1

# ---- Email (platform / ops mail) -------------------------------------------
# These configure Django's global SMTP backend, used for:
#   - mail_admins() ops alerts (axes bursts, ops-checklist digest, ...)
#   - super-admin / system mail (no tenant context)
# Per-tenant member mail uses its own SMTP creds from TenantEmailConfig.
# Any SMTP relay works: your own host, Posteo, IONOS, Mailgun-SMTP, etc.
# REQUIRED in prod: the backend refuses to boot if EMAIL_HOST is empty or
# loopback (an unreachable transport silently drops every ops alert, which
# fail_silently swallows). Set it to a real, reachable SMTP host.
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-smtp-user
EMAIL_HOST_PASSWORD=change-me
DEFAULT_FROM_EMAIL=noreply@jasmin.example.com
SERVER_EMAIL=admin@jasmin.example.com
EMAIL_ADMIN=admin@jasmin.example.com

# ---- Locale -----------------------------------------------------------------
TIME_ZONE=Europe/Berlin

# ---- Frontend build args ----------------------------------------------------
VITE_API_URL=/api
VITE_APP_NAME=Jasmin Platform
# Subdomain that serves the super-admin / platform app. Must match the
# backend ``SUPER_ADMIN_SUBDOMAIN`` above. Default: marillen
VITE_SUPER_ADMIN_SUBDOMAIN=marillen

# ---- Error monitoring (self-hosted GlitchTip) ------------------------------
# After first ``docker compose up``: open the GlitchTip UI (SSH-tunnel
# in prod: ``ssh -L 8004:localhost:8004 <host>`` → http://localhost:8004),
# create the admin account + a project, copy its DSN here.
# Leave empty to disable error reporting (init block in settings.py /
# main.tsx is a no-op when DSN is unset).
# Dedicated least-privileged Postgres role for GlitchTip — NOT the tenant-DB
# superuser (so a GlitchTip compromise can't yield the tenant-DB creds). Create
# it once on the live DB (see the docker-compose.yml GlitchTip comment):
#   CREATE ROLE glitchtip LOGIN PASSWORD '<GLITCHTIP_DB_PASSWORD>';
#   CREATE DATABASE glitchtip OWNER glitchtip;
GLITCHTIP_DB_USER=glitchtip
GLITCHTIP_DB_PASSWORD=change-me-strong
GLITCHTIP_SECRET_KEY=change-me-min-50-chars-different-from-django-secret-key
GLITCHTIP_DOMAIN=https://errors.jasmin.example.com
SENTRY_DSN=
VITE_SENTRY_DSN=

# ---- Friendly Captcha (bot / spam protection on anonymous auth) ------------
# Ships dormant. Once the FC DPA is signed and a Site is created:
#   1) set ENABLED=True
#   2) paste the sitekey + secret from the FC dashboard
# The sitekey is public (shipped to anonymous callers via
# /api/tenants/current/). The secret is server-side only — keep it out
# of any client-facing surface and out of git. See
# apps/accounts/services/friendly_captcha_service.py for the wiring
# and docs/security/access-hardening.md → Related code for the audit
# trail.
FRIENDLY_CAPTCHA_ENABLED=False
FRIENDLY_CAPTCHA_SITEKEY=
FRIENDLY_CAPTCHA_SECRET=
# Override only if FC ever exposes a regional endpoint; default is the
# global siteverify URL.
# FRIENDLY_CAPTCHA_VERIFY_URL=https://api.friendlycaptcha.com/api/v1/siteverify
# Hard timeout on the siteverify call. The service fails CLOSED on
# timeout — bumping this beyond ~10s makes the auth endpoints feel slow
# on FC outages.
# FRIENDLY_CAPTCHA_TIMEOUT_SECONDS=5.0

# ---- Step-up authentication (sudo mode on destructive endpoints) -----------
# Default 300 (5 minutes) — once you've re-confirmed your password,
# further destructive actions within this window skip the prompt.
# See docs/security/access-hardening.md → Part 2 for the gated endpoints.
# STEP_UP_TTL_SECONDS=300
# Flip to True after TOTP MFA rolls out to require a fresh code in
# addition to the password on every step-up.
# STEP_UP_REQUIRES_TOTP=False

# ---- First-deploy platform SuperAdmin (optional) ----------------------------
# If both are set, the entrypoint runs ``createsuperadmin --update-if-exists``
# to create/refresh the public-schema SuperAdmin (email IS the login — there is
# no separate username). Password must be ≥10 chars and not all-numeric.
# Failures are non-fatal (logged; boot continues).
# DJANGO_SUPERUSER_EMAIL=admin@jasmin.example.com
# DJANGO_SUPERUSER_PASSWORD=change-me-min-10-chars
