# =============================================================================
# Jasmin Platform - DEVELOPMENT env (copy to .env.dev)
# Used by:
#   docker compose -f docker-compose.dev.yml --env-file .env.dev up
# Sensible defaults are baked into compose; override here if needed.
# =============================================================================

POSTGRES_DB=jasmin
POSTGRES_USER=jasmin
POSTGRES_PASSWORD=DontForgetMeAgain

DJANGO_SECRET_KEY=dev-secret-key-change-in-production
FIELD_ENCRYPTION_KEY=HeQ7tkqHP7nVB1hA7VkX0SVIan3y_NUFrjyeDnfzcXk=

TIME_ZONE=Europe/Berlin

# ---- Error monitoring (self-hosted GlitchTip) ------------------------------
# Optional. Open http://localhost:8004 after ``docker compose -f
# docker-compose.dev.yml up -d glitchtip-web``, register the admin
# account, create a project, paste its DSN below. Restart Django (and
# rebuild Vite) so the SDK init picks it up. Empty = SDKs no-op.
GLITCHTIP_SECRET_KEY=dev-glitchtip-secret-key-change-in-prod
GLITCHTIP_DOMAIN=http://localhost:8004
SENTRY_DSN=
VITE_SENTRY_DSN=

# ---- Friendly Captcha (off by default in dev) ------------------------------
# Defaults are safe for dev — leave ENABLED=False so anonymous auth
# endpoints don't require a solution token. Set to True + paste your
# sitekey/secret to exercise the gate locally.
# FRIENDLY_CAPTCHA_ENABLED=False
# FRIENDLY_CAPTCHA_SITEKEY=
# FRIENDLY_CAPTCHA_SECRET=

# ---- Step-up auth (sudo mode TTL) ------------------------------------------
# Lower this locally when poking at the gated endpoints (GDPR approve,
# role grant, backup trigger) so you can watch the timeout kick in.
# STEP_UP_TTL_SECONDS=300
# STEP_UP_REQUIRES_TOTP=False
